<Window x:Class="MyNotes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Overlay Notepad App"
        WindowStyle="None"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized">

    <Canvas x:Name="MainCanvas">

        <Border Background="#F5F9FC"            
            BorderBrush="#87CEEB"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Width="320" Height="620"
                Canvas.Right="40" Canvas.Top="60">

            <Grid>
                <ListBox x:Name="FileList"
                         Visibility="Collapsed"
                         Foreground="White"
                         Background="Blue"
                         BorderThickness="0"
                         Padding="8"
                         SelectionChanged="FileList_SelectionChanged"/>
            </Grid>
        </Border>

        <Button x:Name="OverlayButton"
                Content="Notes"
                Width="80" Height="40"
                Canvas.Right="20" Canvas.Bottom="20"
                FontSize="16" FontWeight="SemiBold"
                Foreground="White"
                Click="OverlayButton_Click"
                MouseDoubleClick="OverlayButton_DoubleClick">

            <Button.Background>
                <SolidColorBrush Color="#87CEEB" Opacity="0.45"/>
            </Button.Background>

            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1.5"
                                        CornerRadius="12"
                                        Opacity="{TemplateBinding Opacity}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background">
                                            <Setter.Value>
                                                <SolidColorBrush Color="#A0D8F0" Opacity="0.70"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background">
                                            <Setter.Value>
                                                <SolidColorBrush Color="#B0E0F6" Opacity="0.85"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>

    </Canvas>
</Window>