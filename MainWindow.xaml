<Window x:Class="MyNotes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MyNotes.Helpers"
        Title="Overlay Notepad App"
        WindowStyle="None"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        Loaded="MainWindow_Loaded">
    <Window.Resources>
        <local:WidthToOrientationConverter x:Key="WidthToOrientationConverter"/>
        <local:WidthToActionButtonVisibilityConverter x:Key="WidthToActionButtonVisibilityConverter"/>
        <local:WidthToHeaderVisibilityConverter x:Key="WidthToHeaderVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        
        <!-- Scrollbar thumb style -->
        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="4"/>
            <Setter Property="MinWidth" Value="4"/>
            <Setter Property="MaxWidth" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#B3D8EA" CornerRadius="6" Margin="2,2,2,2" Width="4" MinWidth="4" MaxWidth="4"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Modern scrollbar styling -->
        <Style x:Key="ModernScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
            <Setter Property="MaxWidth" Value="6"/>
            <Setter Property="Background" Value="#E6F2F8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Width="6" MinWidth="6" MaxWidth="6">
                            <Grid>
                                <Track x:Name="PART_Track" IsDirectionReversed="True" Width="6" MinWidth="6" MaxWidth="6">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.LineUpCommand" Background="Transparent" BorderThickness="0" Foreground="Transparent" Width="6" MinWidth="6" MaxWidth="6"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ScrollBarThumbStyle}"/>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.LineDownCommand" Background="Transparent" BorderThickness="0" Foreground="Transparent" Width="6" MinWidth="6" MaxWidth="6"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D0EAF7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Apply modern scrollbar style globally -->
        <Style TargetType="ScrollBar" BasedOn="{StaticResource ModernScrollBar}"/>
    </Window.Resources>

        <Canvas x:Name="MainCanvas"
            Background="Transparent"
            Focusable="True">

        <Border x:Name="NotesPanel"
            Background="#F5F9FC"
            BorderBrush="#87CEEB"
            Opacity="0.88"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12"
            Focusable="True"
            MinWidth="220"
            MinHeight="180"
            Width="360" Height="620"
            Canvas.Right="40" Canvas.Top="60"
            Visibility="Visible">

            <Grid>
                <DockPanel>
                <!-- Header bar -->
                <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="NotesPanelDragHandle"
                        Grid.Column="0"
                        Background="Transparent"
                        Focusable="True"
                        Cursor="SizeAll"
                        Padding="0,4,8,4">
                        <Grid>
                            <TextBlock x:Name="HeaderText"
                                       Text="{Binding HeaderText, Mode=OneWay}"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="#2C6E91"
                                       VerticalAlignment="Center"
                                       ToolTip="Double-click to set a custom header for your app"
                                       Visibility="{Binding ElementName=NotesPanel, Path=ActualWidth, Converter={StaticResource WidthToHeaderVisibilityConverter}}"/>
                            <TextBox x:Name="HeaderTextEdit"
                                     FontSize="16" FontWeight="SemiBold"
                                     Foreground="#2C6E91"
                                     VerticalAlignment="Center"
                                     Visibility="Collapsed"
                                     MinWidth="80"
                                     ToolTip="Enter a custom header and press Enter to save"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="8,0,0,0">
                        <Button x:Name="NewNoteButton"
                                Content="+ New"
                                Click="NewNoteButton_Click"
                                FontSize="12" FontWeight="SemiBold"
                                Foreground="White" Cursor="Hand"
                                Padding="10,4" Margin="0,0,6,0"
                                MinWidth="0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=NotesPanel, Path=ActualWidth}" Value="320">
                                            <Setter Property="Content" Value="&#xE710;"/>
                                            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                                            <Setter Property="FontSize" Value="18"/>
                                            <Setter Property="Padding" Value="10,4"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="#5BA8C8"
                                            CornerRadius="5" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#4A97B7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="SettingsButton"
                                Content="Settings"
                                Click="SettingsButton_Click"
                                FontSize="12" FontWeight="SemiBold"
                                Foreground="White" Cursor="Hand"
                                Padding="10,4" Margin="0,0,6,0"
                                MinWidth="0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=NotesPanel, Path=ActualWidth}" Value="320">
                                            <Setter Property="Content" Value="&#xE713;"/>
                                            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                                            <Setter Property="FontSize" Value="18"/>
                                            <Setter Property="Padding" Value="10,4"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="#617A8A"
                                            CornerRadius="5" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#516774"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="MinimizeNotesButton"
                                Content="Hide"
                                Click="MinimizeNotesButton_Click"
                                FontSize="10" FontWeight="SemiBold"
                                Foreground="White" Cursor="Hand"
                                Padding="10,4"
                                Margin="0,0,0,0"
                                MinWidth="0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=NotesPanel, Path=ActualWidth}" Value="320">
                                            <Setter Property="Content" Value="&#xE711;"/>
                                            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                                            <Setter Property="FontSize" Value="18"/>
                                            <Setter Property="Padding" Value="10,4"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="#6C86A0"
                                            CornerRadius="5" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#5B748D"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Separator -->
                <Border DockPanel.Dock="Top"
                    Height="1" Background="#D0E4EE" Margin="0,0,0,2"/>

                <Grid>
                    <Border x:Name="NotesContentBackground"
                        Background="#D9F5F9FC"
                        BorderBrush="#D8E9F1"
                        BorderThickness="1"
                        CornerRadius="8"/>

                    <DockPanel x:Name="NotesListView"
                              Margin="8"
                              Opacity="0.95">

                        <!-- File list -->
                        <ListBox x:Name="FileList"
                                 Foreground="#333333"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0"
                                 SelectionChanged="FileList_SelectionChanged"
                                 KeyDown="FileList_KeyDown"
                                 MinHeight="60"
                                 VerticalAlignment="Stretch"
                                 DockPanel.Dock="Bottom"
                              
                                 Margin="0,0,4,0">
                                <ListBox.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Open"
                                                  Click="OpenSelectedNote_Click"
                                                  InputGestureText="Enter"
                                                  ToolTip="Open this note (Enter)">
                                            <MenuItem.Icon>
                                                <Image Width="16" Height="16" Source="pack://application:,,,/Resources/open.png"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Rename"
                                                  Click="RenameNote_Click"
                                                  InputGestureText="F2"
                                                  ToolTip="Rename this note (F2)">
                                            <MenuItem.Icon>
                                                <Image Width="16" Height="16" Source="pack://application:,,,/Resources/rename.png"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Copy Note Name"
                                                  Click="CopyNoteName_Click"
                                                  InputGestureText="Ctrl+C"
                                                  ToolTip="Copy note name to clipboard">
                                            <MenuItem.Icon>
                                                <Image Width="16" Height="16" Source="pack://application:,,,/Resources/copy.png"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <Separator/>
                                        <MenuItem Header="Delete Note"
                                                  Click="DeleteNoteButton_Click"
                                                  InputGestureText="Del"
                                                  ToolTip="Delete this note (Del)">
                                            <MenuItem.Icon>
                                                <Image Width="16" Height="16" Source="pack://application:,,,/Resources/delete.png"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </ListBox.ContextMenu>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="16"/> <!-- Pin icon space, moved slightly more left -->
                                                <ColumnDefinition Width="*" MinWidth="50"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Pin icon column -->
                                            <Grid Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <Button Width="16" Height="16" Padding="1" Margin="-7,0,0,0"
                                                        FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                        Content="&#xE718;"
                                                        ToolTip="Pin note"
                                                        Foreground="#C9302C"
                                                        Cursor="Hand"
                                                        Background="Transparent"
                                                        BorderBrush="Transparent"
                                                        BorderThickness="1"
                                                        Click="PinNoteButton_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Setter Property="Opacity" Value="1"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Setter Property="Opacity" Value="0.8"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                            <!-- Note display column -->
                                            <Grid Grid.Column="1" Margin="0,0,8,0">
                                                <StackPanel x:Name="DisplayPanel">
                                                    <TextBlock x:Name="DisplayTextBlock"
                                                               Text="{Binding DisplayName}"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding DisplayName}"/>
                                                    <TextBlock Text="{Binding Subtitle}"
                                                               Margin="0,2,0,0"
                                                               FontSize="11"
                                                               Foreground="#5F7480"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding Subtitle}"
                                                               Visibility="{Binding DataContext.ShowModifiedSubtitle, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"/>
                                                </StackPanel>
                                                <TextBox x:Name="EditTextBox" 
                                                         Text="{Binding EditableName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Visibility="Collapsed"
                                                         Padding="2"
                                                         Background="White"
                                                         BorderBrush="#5BA8C8"
                                                         BorderThickness="1"
                                                         KeyDown="RenameTextBox_KeyDown"
                                                         LostFocus="RenameTextBox_LostFocus"/>
                                            </Grid>
                                            <!-- Action buttons column -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                                                <Button Content="Rename"
                                                        Click="RenameNote_Click"
                                                        Padding="8,2"
                                                        FontSize="10"
                                                        FontWeight="SemiBold"
                                                        Foreground="#2C6E91"
                                                        Cursor="Hand"
                                                        Background="Transparent"
                                                        BorderBrush="#9EC7DB"
                                                        BorderThickness="1"
                                                        MinWidth="40"
                                                        Visibility="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=ActualWidth, Converter={StaticResource WidthToActionButtonVisibilityConverter}, ConverterParameter=rename}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="bg"
                                                                    Background="#EFF7FB"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="6"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bg" Property="Background" Value="#DCEEF8"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <Button Click="DeleteNoteButton_Click"
                                                        Width="20"
                                                        Height="20"
                                                        Margin="6,0,0,0"
                                                        Padding="0"
                                                        FontFamily="Segoe MDL2 Assets"
                                                        FontSize="12"
                                                        Content="&#xE74D;"
                                                        ToolTip="Delete note"
                                                        Foreground="#C9302C"
                                                        Cursor="Hand"
                                                        Background="Transparent"
                                                        BorderBrush="#E8B2AF"
                                                        BorderThickness="1"
                                                        Visibility="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=ActualWidth, Converter={StaticResource WidthToActionButtonVisibilityConverter}, ConverterParameter=delete}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="bg"
                                                                    Background="#FFF4F3"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="6"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bg" Property="Background" Value="#FCE2E0"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                <Setter TargetName="DisplayPanel" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="EditTextBox" Property="Visibility" Value="Visible"/>
                                                <!-- Action buttons will be hidden by the DataContext logic if needed -->
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="8,6"/>
                                        <Setter Property="Margin" Value="0,2"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <EventSetter Event="PreviewMouseLeftButtonUp" Handler="ListBoxItem_MouseLeftButtonUp"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="ItemBorder"
                                                            Background="Transparent"
                                                            CornerRadius="6"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="Background" Value="#E0F0FA"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="Background" Value="#C4E2F2"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                    </DockPanel>

                        <StackPanel x:Name="SettingsView" Margin="0,4,0,0">
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="User Settings"
                                           Grid.Column="0"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="#2C6E91"
                                           VerticalAlignment="Center"/>

                                <Button x:Name="BackToNotesButton"
                                        Grid.Column="1"
                                        Content="Back"
                                        Click="BackToNotesButton_Click"
                                        FontSize="13"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Cursor="Hand"
                                        Padding="18,6"
                                        Background="#2C6E91"
                                        BorderThickness="0"
                                        Margin="8,0,0,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg"
                                                    Background="#2C6E91"
                                                    CornerRadius="16"
                                                    Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="&#xE72B;"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="13"
                                                               Margin="0,0,8,0"
                                                               VerticalAlignment="Center"/>
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#1B4F6B"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#153B4F"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <Border Background="#EFF7FB"
                                    BorderBrush="#C9DFEC"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Note Naming"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#355A6E"
                                               Margin="0,0,0,8"/>
                                    <CheckBox x:Name="PromptForNoteNameOption"
                                            Foreground="#355A6E"
                                            FontWeight="SemiBold"
                                            Checked="PromptForNoteNameOption_Changed"
                                            Unchecked="PromptForNoteNameOption_Changed"
                                            Margin="0,0,0,0"
                                            HorizontalAlignment="Stretch">
                                        <TextBlock Text="Ask for note name when creating a new note"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"/>
                                    </CheckBox>
                                    <CheckBox x:Name="ShowModifiedSubtitleOption"
                                            Foreground="#355A6E"
                                            FontWeight="SemiBold"
                                            Margin="0,6,0,0"
                                            Checked="ShowModifiedSubtitleOption_Changed"
                                            Unchecked="ShowModifiedSubtitleOption_Changed"
                                            HorizontalAlignment="Stretch">
                                        <TextBlock Text="Show 'Modified' timestamp in note subtitle"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"/>
                                    </CheckBox>
                                </StackPanel>
                            </Border>

                            <Border Background="#EFF7FB"
                                    BorderBrush="#C9DFEC"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="New Note Timestamp"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                              Foreground="#355A6E"
                                               Margin="0,0,0,8"/>
                                    <RadioButton x:Name="TimestampNoneOption"
                                                 GroupName="TimestampPlacement"
                                                 Margin="0,0,0,6"
                                                 Checked="TimestampPlacementOption_Checked"
                                                 HorizontalAlignment="Stretch">
                                        <TextBlock Text="No timestamp"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                    </RadioButton>
                                    <RadioButton x:Name="TimestampTopOption"
                                                 GroupName="TimestampPlacement"
                                                 Margin="0,0,0,6"
                                                 Checked="TimestampPlacementOption_Checked"
                                                 HorizontalAlignment="Stretch">
                                        <TextBlock Text="Add timestamp to top of page"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                    </RadioButton>
                                    <RadioButton x:Name="TimestampBottomOption"
                                                 GroupName="TimestampPlacement"
                                                 Checked="TimestampPlacementOption_Checked"
                                                 HorizontalAlignment="Stretch">
                                        <TextBlock Text="Add timestamp to bottom of page"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                    </RadioButton>
                                </StackPanel>
                            </Border>

                            <Border Background="#EFF7FB"
                                    BorderBrush="#C9DFEC"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Notes Folder"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#355A6E"
                                                   Margin="0,0,8,0"/>
                                        <Button x:Name="ShowHideNotesDirectoryButton"
                                                Content="Show Folder"
                                                Click="ShowHideNotesDirectoryButton_Click"
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Foreground="#2C6E91"
                                                Cursor="Hand"
                                                Padding="6,2"
                                                Margin="0,0,0,0"
                                                Background="Transparent"
                                                BorderBrush="#9EC7DB"
                                                BorderThickness="1"/>
                                    </StackPanel>
                                    <TextBlock x:Name="SettingsNotesDirectoryText"
                                               FontSize="11"
                                               Foreground="#5F7480"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,10"
                                               Visibility="{Binding ShowNotesDirectory, Converter={StaticResource BoolToVisibility}, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    <Button x:Name="ChangeFolderButton"
                                            Content="Change Folder"
                                            Click="ChangeFolderButton_Click"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Foreground="#2C6E91"
                                            Cursor="Hand"
                                            Padding="8,3"
                                            HorizontalAlignment="Left"
                                            Background="Transparent"
                                            BorderBrush="#9EC7DB"
                                            BorderThickness="1">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg"
                                                        Background="#EFF7FB"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#DCEEF8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                </Grid>
                </DockPanel>

                <Thumb x:Name="NotesPanelResizeThumb"
                       Width="18"
                       Height="18"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"
                       Margin="0,0,1,1"
                       Cursor="SizeNWSE"
                       DragDelta="NotesPanelResizeThumb_DragDelta">
                    <!-- Always show the resize thumb, even at minimum width -->
                    <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                            <Border Background="Transparent">
                                <Grid HorizontalAlignment="Right"
                                      VerticalAlignment="Bottom"
                                      Margin="0,0,2,2">
                                    <Path Data="M 0 10 L 10 0 M 4 10 L 10 4 M 8 10 L 10 8"
                                          Stroke="#6E90A5"
                                          StrokeThickness="1.2"
                                          SnapsToDevicePixels="True"/>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>
            </Grid>
        </Border>

        <Popup x:Name="RenameNoticePopup"
               AllowsTransparency="True"
               Focusable="False"
               IsHitTestVisible="False"
               Placement="Relative"
               PlacementTarget="{Binding ElementName=NotesPanel}"
               StaysOpen="True">
            <Border Width="220"
                    Padding="12,10"
                    Background="#FFF5D9"
                    BorderBrush="#E5C97A"
                    BorderThickness="1"
                    CornerRadius="10"
                    SnapsToDevicePixels="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14"
                                      Direction="270"
                                      Opacity="0.18"
                                      ShadowDepth="4"
                                      Color="#000000"/>
                </Border.Effect>
                <TextBlock x:Name="RenameNoticeText"
                           FontSize="11"
                           Foreground="#7B5A12"
                           TextWrapping="Wrap"/>
            </Border>
        </Popup>

        <Button x:Name="OverlayButton"
                Content="Notes"
            Width="96" Height="48"
                Canvas.Right="20" Canvas.Bottom="20"
                FontSize="16" FontWeight="SemiBold"
            Foreground="White">

            <Button.Background>
                <SolidColorBrush Color="#87CEEB" Opacity="0.45"/>
            </Button.Background>

            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1.5"
                                        CornerRadius="12"
                                        Opacity="{TemplateBinding Opacity}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background">
                                            <Setter.Value>
                                                <SolidColorBrush Color="#A0D8F0" Opacity="0.70"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background">
                                            <Setter.Value>
                                                <SolidColorBrush Color="#B0E0F6" Opacity="0.85"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>

    </Canvas>
</Window>
